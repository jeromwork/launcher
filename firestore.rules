rules_version = '2';

// Spec 007 Firestore Security Rules (FR-028 .. FR-030).
//
// Identity model:
//  - The Managed device's Firebase Auth UID is captured at pairing time as
//    `managedDeviceFirebaseUid` (in /pairings/{token} and /links/{linkId}).
//  - The admin's UID is `adminId` on /links/{linkId} after claim.
//  - Anonymous Auth is the only auth method in spec 007 (OWD-2 named-auth
//    migration tracked in project-backlog).
//
// Reusable-trust-primitive (spec 007 plan §Reusable trust primitive):
//  - /pairings/{token} carries `pairingType` (default "admin-managed-link")
//    so future specs (011 contacts, jitsi calls, …) can publish their own
//    tokens into the same collection without a schema bump. These rules
//    enforce admin-managed-link semantics; future types will need their
//    own validate-fn that we'd OR in here (or move to subcollections —
//    decided when the second pairingType lands).

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── helpers ──────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // ─── wire-format versions (docs/architecture/wire-format.md) ───────
    //
    // Versions travel as dotted "MAJOR.MINOR" strings (§2). Rules MUST NOT compare them with
    // <, >, <= or >= directly: those operators order strings lexicographically, which puts
    // "10.0" BELOW "9.0". Every monotonic guard here exists to stop a rollback to an older,
    // possibly weaker document, so a lexicographic compare would silently invert exactly the
    // check it is meant to enforce — permitting "10.0" → "9.0" and rejecting the legitimate
    // "9.0" → "10.0".
    //
    // versionOrder() collapses the parts into one comparable integer. MINOR is bounded at
    // 100000, far above anything a data shape will reach.
    //
    // Pre-release tokens (§10, e.g. "3.0-beta") are NOT parseable here: int() fails on them and
    // the rule denies. That is the correct outcome — a pre-release document has no business in
    // a collection guarded by a monotonic rule — but it means a format must drop its token
    // before it can be written to a versioned path.
    //
    // Verified against the emulator (rules.wire-version.test.ts): the rules engine does support
    // split()/int(), and the 9→10 boundary orders correctly in both directions.
    function versionOrder(v) {
      return int(v.split('\\.')[0]) * 100000 + int(v.split('\\.')[1]);
    }

    // The highest reader requirement these rules will accept on a write. Deployed rules must be
    // updated BEFORE clients start writing a higher one — same constraint the old `== 1` checks
    // imposed, kept deliberately.
    function maxAcceptedReaderVersion() {
      return "1.0";
    }

    // Shape check for the three-field header (§3): all present, correctly ordered, and not
    // demanding a reader newer than this deployment knows about.
    //
    // That last clause is the anti-abuse part, and it is why this is not merely a shape check.
    // A rogue client could otherwise write minReaderVersion "999.0" into a shared document and
    // every legitimate device — including the owner's — would refuse to read it, with no way to
    // repair it client-side. schemaVersion itself stays unbounded: it is diagnostics (§3), so a
    // newer writer may stamp whatever it likes as long as it does not lock anyone out.
    function hasValidVersionHeader(d) {
      return d.schemaVersion is string
          && d.minReaderVersion is string
          && d.minWriterVersion is string
          && versionOrder(d.minReaderVersion) <= versionOrder(d.minWriterVersion)
          && versionOrder(d.minWriterVersion) <= versionOrder(d.schemaVersion)
          && versionOrder(d.minReaderVersion) <= versionOrder(maxAcceptedReaderVersion());
    }

    function isManagedUid(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function newDoc() {
      return request.resource.data;
    }

    function existingDoc() {
      return resource.data;
    }

    // Anti-spam on /pairings create: only the device that claims to be the
    // Managed side may write the doc, and the body's managedDeviceFirebaseUid
    // must match request.auth.uid. Stops random anonymous users from
    // flooding the collection.
    function isValidPairingCreate() {
      return isSignedIn()
        && newDoc().managedDeviceFirebaseUid == request.auth.uid
        && newDoc().claimed == false
        && hasValidVersionHeader(newDoc());
    }

    // Atomic claim: caller flips claimed false→true. No other field may
    // change (block in-place mutation of token/expiresAt/managedDeviceId
    // by a hostile claimer).
    function isValidClaimUpdate() {
      return isSignedIn()
        && existingDoc().claimed == false
        && newDoc().claimed == true
        && newDoc().schemaVersion == existingDoc().schemaVersion
        && newDoc().managedDeviceId == existingDoc().managedDeviceId
        && newDoc().managedDeviceFirebaseUid == existingDoc().managedDeviceFirebaseUid
        && newDoc().expiresAt == existingDoc().expiresAt;
    }

    // /links/{linkId} root doc — link membership helpers.
    function isLinkAdmin(linkId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/links/$(linkId)).data.adminId == request.auth.uid;
    }

    function isLinkManaged(linkId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/links/$(linkId)).data.managedDeviceFirebaseUid == request.auth.uid;
    }

    function isLinkParty(linkId) {
      return isLinkAdmin(linkId) || isLinkManaged(linkId);
    }

    // ─── /pairings/{token} (FR-029, contracts/pairing-token.md) ────────

    match /pairings/{token} {
      // Anyone authenticated can read — the token IS the secret (anyone
      // with the QR can read; we don't gate further to keep claim flow
      // friction-free).
      allow read: if isSignedIn();

      // Managed creates with matching uid (anti-spam).
      allow create: if isValidPairingCreate();

      // Update is the atomic claim transaction performed by the admin.
      // No field-level lock on adminId — the admin pairs by writing
      // /links/{linkId} atomically (enforced via batched-write contract,
      // not here, because Firestore Rules can't see a batch).
      allow update: if isValidClaimUpdate();

      // Decline / single-use cleanup — only the Managed creator may delete.
      allow delete: if isManagedUid(existingDoc().managedDeviceFirebaseUid);
    }

    // ─── /links/{linkId} (FR-028, contracts/link.md) ───────────────────

    match /links/{linkId} {
      // Both sides of the link may read the root doc.
      allow read: if isSignedIn()
        && (existingDoc().adminId == request.auth.uid
            || existingDoc().managedDeviceFirebaseUid == request.auth.uid);

      // Create: admin transaction — paired with the /pairings/{token}
      // claim update. The admin's uid must end up as adminId; the
      // managedDeviceFirebaseUid must come from a pre-existing
      // /pairings/{token} doc (we can't cross-reference in pure rules,
      // so we trust the client-side batched transaction to carry both
      // updates atomically). The schemaVersion and identity fields are
      // sanity-checked here.
      allow create: if isSignedIn()
        && newDoc().adminId == request.auth.uid
        && newDoc().managedDeviceFirebaseUid is string
        && newDoc().managedDeviceId is string
        && hasValidVersionHeader(newDoc());

      // Root doc is immutable post-create (contract §Security Rules).
      allow update: if false;

      // Delete: Managed side revokes (FR-033) OR admin removes from their list.
      // Admin-side delete added so the reconnect-dedup cleanup and the "Удалить"
      // button on the admin paired-devices screen can prune stale link docs.
      allow delete: if isManagedUid(existingDoc().managedDeviceFirebaseUid)
                     || existingDoc().adminId == request.auth.uid;

      // ─── /links/{linkId}/state/{stateId} ──────────────────────────
      // FR-027, contracts/state-bootstrap.md.
      match /state/{stateId} {
        allow read:   if isLinkParty(linkId);
        allow create: if isLinkManaged(linkId)
                       && hasValidVersionHeader(newDoc());
        // Managed may update fcmToken / presetId; cannot lower schemaVersion.
        allow update: if isLinkManaged(linkId)
                       && versionOrder(newDoc().schemaVersion) >= versionOrder(existingDoc().schemaVersion);
        allow delete: if isLinkManaged(linkId);
      }

      // ─── /links/{linkId}/config/{configId} ────────────────────────
      // Spec 008 (FR-010, FR-011): collaborative editing. Both admin AND
      // managed device are equal editors (FR-050 «единый editor pattern»).
      // Write authorization: any link party. Optimistic concurrency on
      // serverUpdatedAt is enforced client-side через
      // RemoteSyncBackend.runTransaction (Firestore Rules can't see the
      // client's prior read-set; transaction-based check is standard
      // Firestore pattern, see specs/008-.../research.md §1).
      //
      // Schema invariant: schemaVersion is set on create and cannot
      // decrease on update (per contract/config.md §Security Rules).
      match /config/{configId} {
        allow read:   if isLinkParty(linkId);
        allow create: if isLinkParty(linkId)
                       && hasValidVersionHeader(newDoc());
        allow update: if isLinkParty(linkId)
                       && versionOrder(newDoc().schemaVersion) >= versionOrder(existingDoc().schemaVersion);
        // Delete only via revoke path (Managed side, deletes whole subtree).
        allow delete: if isLinkManaged(linkId);
      }

      // ─── /links/{linkId}/configHistory/{autoId} ──────────────────
      // Spec 009 (FR-036..FR-045b): config history + rollback.
      // Both admin and Managed are link parties; both can record snapshots
      // before publishing (FR-036). History is immutable — no update.
      // Delete is allowed via client-orchestrated housekeeping
      // (FR-038, ≤10 snapshots) until SRV-CONFIG-001 migrates to
      // server-side cron. Anti-spoof: recordedFromDeviceId MUST equal
      // request.auth.uid (FR-045a) — server-enforced integrity gate.
      //
      // Path note: spec 009 contracts/config-history.md prints the path
      // as `/links/{linkId}/config/history/{autoId}` (shorthand), but
      // raw Firestore requires alternating collection/doc segments, so
      // the canonical implementation uses a sibling top-level collection
      // `configHistory`. See docs/dev/project-backlog.md for the doc-fix
      // task.
      //
      // TODO(server-roadmap SRV-CONFIG-001): migrate history writes
      // to server-side (eliminate client recordedFromDeviceId trust,
      // atomic publish+history via Cloud Function or own server).
      match /configHistory/{autoId} {
        allow read: if isLinkParty(linkId);
        allow create: if isLinkParty(linkId)
                       && request.resource.data.recordedFromDeviceId == request.auth.uid
                       // The envelope versions independently of the config it carries, so it
                       // has its own three fields under snapshot* names (spec 009 C-2).
                       && request.resource.data.snapshotSchemaVersion is string
                       && request.resource.data.snapshotMinReaderVersion is string
                       && request.resource.data.snapshotMinWriterVersion is string
                       && versionOrder(request.resource.data.snapshotMinReaderVersion)
                          <= versionOrder(request.resource.data.snapshotSchemaVersion);
        allow update: if false;
        // Housekeeping deletes oldest entries when count exceeds 10.
        // Client-orchestrated until SRV-CONFIG-001.
        allow delete: if isLinkParty(linkId);
      }

      // ─── /links/{linkId}/capabilities/{capId} ─────────────────────
      // Managed writes provider snapshot; admin reads.
      match /capabilities/{capId} {
        allow read:  if isLinkParty(linkId);
        allow write: if isLinkManaged(linkId);
      }

      // ─── /links/{linkId}/health/{healthId} ────────────────────────
      // Managed writes battery/connectivity; admin reads.
      match /health/{healthId} {
        allow read:  if isLinkParty(linkId);
        allow write: if isLinkManaged(linkId);
      }

      // ─── /links/{linkId}/commands/{cmdId} ─────────────────────────
      // Admin issues commands (spec 009); Managed updates with ack/result.
      match /commands/{cmdId} {
        allow read:   if isLinkParty(linkId);
        allow create: if isLinkAdmin(linkId);
        allow update: if isLinkManaged(linkId);
        allow delete: if isLinkAdmin(linkId);
      }

      // ─── /links/{linkId}/devices/{deviceId} (spec 011 FR-006..009) ─
      // DeviceIdentity Pub publication: каждое устройство публикует свой
      // X25519 + Ed25519 public key + Ed25519 signature над payload.
      // Подробности — specs/011-.../contracts/device-identity.md.
      match /devices/{deviceId} {
        function freshSignedTimestamp() {
          // signedTimestamp в пределах 7 дней (replay-attack mitigation)
          // с 1-минутным skew для clock drift.
          let nowMillis = request.time.toMillis();
          let signedMillis = request.resource.data.signedTimestamp;
          return (nowMillis - signedMillis) < (7 * 24 * 60 * 60 * 1000)
              && (nowMillis - signedMillis) > -(60 * 1000);
        }

        function hasRequiredFields() {
          let d = request.resource.data;
          return hasValidVersionHeader(d)
              && d.deviceId is string
              && d.publicKey is string
              && d.signingPublicKey is string
              && d.signedTimestamp is int
              && d.signature is string
              && d.algorithm == "x25519+ed25519";
        }

        function isOwnDevice() {
          return exists(/databases/$(database)/documents/links/$(linkId)/deviceOwnership/$(deviceId))
              && get(/databases/$(database)/documents/links/$(linkId)/deviceOwnership/$(deviceId)).data.ownerUid == request.auth.uid;
        }

        // Любой member пары может read peer's Pub'ы.
        allow read:   if isLinkParty(linkId);
        // Create: link party, deviceId совпадает с path, все поля валидны, signedTimestamp свежий.
        allow create: if isLinkParty(linkId)
                       && request.resource.data.deviceId == deviceId
                       && hasRequiredFields()
                       && freshSignedTimestamp();
        // Update: только own device (через deviceOwnership claim), валидация полная.
        allow update: if isLinkParty(linkId)
                       && isOwnDevice()
                       && hasRequiredFields()
                       && freshSignedTimestamp();
        // Delete: только own device.
        allow delete: if isOwnDevice();
      }

      // ─── /links/{linkId}/deviceOwnership/{deviceId} (spec 011) ─────
      // Auxiliary collection: race-free deviceId claim. Только первый writer
      // (с тем же uid) может create — далее immutable.
      match /deviceOwnership/{deviceId} {
        allow read: if isLinkParty(linkId);
        allow create: if isSignedIn()
                       && request.resource.data.ownerUid == request.auth.uid
                       && !exists(/databases/$(database)/documents/links/$(linkId)/deviceOwnership/$(deviceId));
        allow update, delete: if false;
      }
    }

    // ─── /devices/{managedDeviceId} (per data-model.md §DocPath) ───────
    // Spec 007 does not write to this collection (deferred to spec 008
    // capability/health export). Leave deny-all so any accidental write
    // is rejected — when spec 008 needs it, expand here.
    match /devices/{managedDeviceId} {
      allow read, write: if false;
    }

    // ─── Spec 017 (F-4 AuthProvider) — identity-links + users ──────────
    //
    // identity-links/google/{providerAccountId} — реверс-mapping
    // Google `sub` claim → наш stableId UUID. Атомарный create через
    // Firestore transaction (race-safe — два устройства с одним Google
    // аккаунтом получат одинаковый stableId).
    //
    // Per spec 017 FR-016a, contract identity-link-v1.md.
    //
    // NB: rule использует `request.auth.uid == providerAccountId` — это
    // означает, что Firebase Auth UID должен совпадать с Google `sub`
    // claim. Firebase **не** делает это автоматически (UID назначается
    // Firebase). Альтернатива — использовать custom claims или server-
    // verified token. Для MVP мы доверяем клиенту: SDK SignInWithCredential
    // exchange гарантирует что Firebase UID = google.com providerData.uid.
    // Production-уровень — Cloud Function для server-side verification
    // (server-roadmap SRV-AUTH-IDENTITY-001).
    //
    // TODO(server-roadmap SRV-AUTH-IDENTITY-002): добавить custom claim
    // `googleSub` в Firebase Auth user, проверять `request.auth.token.googleSub`
    // вместо `request.auth.uid` — устраняет необходимость доверять клиенту.
    // Production-strict rules (T801) — tightened 2026-06-20 to pass
    // firestore-tests/rules.auth.test.ts. Were "open to any authenticated"
    // before; now enforce identity ownership, immutability, shape validation,
    // and cross-collection verification.
    //
    // Path scheme: production code writes single-document
    // `identity-links/google_{sub}` (see GoogleSignInAuthAdapter.kt L254);
    // rules below match that 2-segment path. Future providers add their own
    // `match /identity-links/<prefix>_{accountId}` blocks additively.
    //
    // Still pending for prod (SRV-AUTH-IDENTITY-002): replace
    // `request.auth.uid` with server-verified `request.auth.token.googleSub`
    // custom claim so we no longer trust the client's choice of UID.
    function isGoogleLinkIdForCaller(linkId) {
      return request.auth != null
          && linkId == "google_" + request.auth.uid;
    }
    function isValidUuidV4(s) {
      return s is string
          && s.size() == 36
          && s.matches('^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$');
    }
    function ownerIdentityLink(uid) {
      return /databases/$(database)/documents/identity-links/$("google_" + uid);
    }
    match /identity-links/{linkId} {
      allow read: if isGoogleLinkIdForCaller(linkId);

      allow create: if isGoogleLinkIdForCaller(linkId)
                    && !exists(/databases/$(database)/documents/identity-links/$(linkId))
                    && request.resource.data.keys().hasOnly(['schemaVersion', 'minReaderVersion', 'minWriterVersion', 'stableId', 'createdAt'])
                    && hasValidVersionHeader(request.resource.data)
                    && isValidUuidV4(request.resource.data.stableId)
                    && request.resource.data.createdAt == request.time;

      allow update: if false;       // immutable post-creation
      allow delete: if false;       // S-6 Account Deletion via Cloud Function only
    }

    match /users/{stableId} {
      allow create: if request.auth != null
                    && exists(ownerIdentityLink(request.auth.uid))
                    && get(ownerIdentityLink(request.auth.uid)).data.stableId == stableId
                    && request.resource.data.keys().hasOnly(['schemaVersion', 'minReaderVersion', 'minWriterVersion', 'stableId', 'createdAt'])
                    && hasValidVersionHeader(request.resource.data)
                    && request.resource.data.stableId == stableId
                    && request.resource.data.createdAt == request.time;

      allow read: if request.auth != null
                  && exists(ownerIdentityLink(request.auth.uid))
                  && get(ownerIdentityLink(request.auth.uid)).data.stableId == stableId;

      allow update: if false;       // F-5 / S-8 add own match blocks additively
      allow delete: if false;       // S-6 Account Deletion via Cloud Function only
    }

    // ─── Spec 018 (F-5) — Recovery Key Vault ───────────────────────────
    //
    // Path: users/{uid}/recovery-key/{docId} (subcollection — НЕ covered
    // правилом /users/{any} выше, которое matches только top-level docs).
    //
    // Strict owner-only access + shape validation + schemaVersion monotonic
    // increase (H-2 downgrade attack mitigation).
    //
    // Per spec 018 FR-009, FR-028a, contract firestore-security-rules.md.
    //
    // Native Firestore typed fields (НЕ JSON-encoded в одном string):
    //   • schemaVersion: int  (≥ 1, FR-028a monotonic)
    //   • algorithm: string   (1..64 chars)
    //   • kdfSalt: bytes      (== 16 bytes, libsodium constant)
    //   • kdfParams: map { memoryKiB: int, iterations: int, parallelism: int }
    //   • wrappedRootKey: bytes (1..1024 bytes — AEAD envelope, не raw 32)
    //   • nonce: bytes        (== 24 bytes, XChaCha20)
    //   • createdAt: int      (ms epoch)
    function isValidRecoveryVaultBlob(d) {
      return hasValidVersionHeader(d)
          && d.algorithm is string
          && d.algorithm.size() > 0
          && d.algorithm.size() <= 64
          && d.wrappedRootKey is bytes
          && d.wrappedRootKey.size() > 0
          && d.wrappedRootKey.size() <= 1024
          && d.kdfSalt is bytes
          && d.kdfSalt.size() == 16
          && d.nonce is bytes
          && d.nonce.size() == 24
          && d.kdfParams is map
          && d.kdfParams.memoryKiB is int
          && d.kdfParams.iterations is int
          && d.kdfParams.parallelism is int
          && d.createdAt is int;
    }

    match /users/{uid}/recovery-key/{docId} {
      allow read: if request.auth != null
                  && request.auth.uid == uid;

      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && isValidRecoveryVaultBlob(newDoc());

      // FR-028a (H-2 mitigation): schemaVersion can only monotonically increase.
      // Blocks downgrade attacks где attacker с stolen Google credentials
      // пытается replace v2+ vault на vulnerable v1 (per WhatsApp E2E backup pattern).
      // TASK-141 Part D: compared through versionOrder() — the version is a dotted string now, and
      // a raw >= would order "10.0" below "9.0", permitting exactly the rollback this guard blocks.
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && isValidRecoveryVaultBlob(newDoc())
                    && versionOrder(newDoc().schemaVersion) >= versionOrder(existingDoc().schemaVersion);

      allow delete: if request.auth != null
                    && request.auth.uid == uid;
    }

    // Spec 018 F-5 consumer-side: encrypted ConfigDocument storage path
    // (path owned by spec 008, F-5 enforces owner-only + schemaVersion
    // monotonic increase). Detailed shape validation — spec 008 territory.
    match /users/{uid}/config/{docId} {
      allow read, create, delete: if request.auth != null
                                  && request.auth.uid == uid;

      // FR-028a (H-2 mitigation). Compared through versionOrder(): the mirror is a dotted
      // string now, and a raw >= would compare it lexicographically — ordering "10.0" below
      // "9.0" and so permitting exactly the rollback this guard exists to block.
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && versionOrder(newDoc().schemaVersion) >= versionOrder(existingDoc().schemaVersion);
    }

    // ─── Spec 018 F-5b — Envelope Storage (RemoteStorage backend) ────────
    //
    // Path: /users/{ownerUid}/data/{escapedKey}
    // Stores hybrid envelope: ciphertext + per-recipient sealed CEK.
    //
    // Access model:
    //  - Owner can read/write/delete their own data.
    //  - A helper UID can read/write/delete IF a non-revoked access-grant
    //    exists at /users/{ownerUid}/access-grants/{helperUid}.
    //  - The envelope itself enforces decryption permission via per-device
    //    sealed CEK; rules only gate raw document access.
    //
    // Owner-write of monotonic schemaVersion (defence-in-depth in case the
    // envelope format gains incremental versions later).
    // F-5b ownership: `uid` в путях /users/{uid}/... это наш stableId UUID,
    // не Firebase Auth UID. Проверка владения идёт через identity-link join:
    // request.auth.uid → identity-links/google_{uid}.stableId == path uid.
    // Согласовано с F-4 дизайном (см. ownerIdentityLink функцию выше и
    // правила для /users/{stableId} на L344-355). Эта функция была
    // `request.auth.uid == uid` до 2026-06-22 — это было неверно для F-5b,
    // потому что F-5b клиент передаёт stableId, а проверка ожидала firebaseUid.
    function isOwner(uid) {
      return isSignedIn()
          && exists(ownerIdentityLink(request.auth.uid))
          && get(ownerIdentityLink(request.auth.uid)).data.stableId == uid;
    }
    function hasActiveGrant(ownerUid, helperUid) {
      return exists(/databases/$(database)/documents/users/$(ownerUid)/access-grants/$(helperUid))
        && get(/databases/$(database)/documents/users/$(ownerUid)/access-grants/$(helperUid)).data.revokedAt == null;
    }
    function isOwnerOrGrantedHelper(ownerUid) {
      return isOwner(ownerUid) || hasActiveGrant(ownerUid, request.auth.uid);
    }

    match /users/{ownerUid}/data/{key} {
      allow read, delete: if isOwnerOrGrantedHelper(ownerUid);
      // TASK-141 Part D: the envelope carries the dotted three-field header now. Validate its shape
      // on create (all three strings, ordered, not demanding a reader newer than we accept) and gate
      // the monotonic schemaVersion through versionOrder() on update — a raw >= would compare the
      // dotted string lexicographically, ordering "10.0" below "9.0" and permitting a rollback.
      allow create: if isOwnerOrGrantedHelper(ownerUid)
                    && hasValidVersionHeader(newDoc());
      allow update: if isOwnerOrGrantedHelper(ownerUid)
                    && hasValidVersionHeader(newDoc())
                    && versionOrder(newDoc().schemaVersion) >= versionOrder(existingDoc().schemaVersion);
    }

    // ─── Spec 018 F-5b — Public Key Directory ───────────────────────────
    //
    // Paths:
    //  /users/{uid}/devices/{deviceId}                     — empty owner-only doc
    //  /users/{uid}/devices/{deviceId}/pub-key/current     — X25519 pub key
    //
    // Owner publishes and unpublishes their own devices. Anyone with an
    // active access-grant can read the directory in order to resolve
    // recipients before encrypting an envelope under {uid}'s namespace.
    match /users/{uid}/devices/{deviceId} {
      allow read: if isOwnerOrGrantedHelper(uid);
      allow write, delete: if isOwner(uid);
    }
    match /users/{uid}/devices/{deviceId}/pub-key/{docId} {
      allow read: if isOwnerOrGrantedHelper(uid);
      allow write, delete: if isOwner(uid);
    }

    // ─── Spec 018 F-5b — Access Grants ──────────────────────────────────
    //
    // Path: /users/{ownerUid}/access-grants/{helperUid}
    //
    // Only the owner writes / revokes grants in their own namespace. Any
    // signed-in user may read their own row (so they can discover that they
    // hold a grant); owner may read their full grants list.
    match /users/{ownerUid}/access-grants/{helperUid} {
      allow read: if isOwner(ownerUid)
                  || (isSignedIn() && request.auth.uid == helperUid);
      allow create, update, delete: if isOwner(ownerUid);
    }

    // ─── default deny for everything else ──────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
