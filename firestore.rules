rules_version = '2';

// Spec 007 Firestore Security Rules (FR-028 .. FR-030).
//
// Identity model:
//  - The Managed device's Firebase Auth UID is captured at pairing time as
//    `managedDeviceFirebaseUid` (in /pairings/{token} and /links/{linkId}).
//  - The admin's UID is `adminId` on /links/{linkId} after claim.
//  - Anonymous Auth is the only auth method in spec 007 (OWD-2 named-auth
//    migration tracked in project-backlog).
//
// Reusable-trust-primitive (spec 007 plan §Reusable trust primitive):
//  - /pairings/{token} carries `pairingType` (default "admin-managed-link")
//    so future specs (011 contacts, jitsi calls, …) can publish their own
//    tokens into the same collection without a schema bump. These rules
//    enforce admin-managed-link semantics; future types will need their
//    own validate-fn that we'd OR in here (or move to subcollections —
//    decided when the second pairingType lands).

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── helpers ──────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isManagedUid(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function newDoc() {
      return request.resource.data;
    }

    function existingDoc() {
      return resource.data;
    }

    // Anti-spam on /pairings create: only the device that claims to be the
    // Managed side may write the doc, and the body's managedDeviceFirebaseUid
    // must match request.auth.uid. Stops random anonymous users from
    // flooding the collection.
    function isValidPairingCreate() {
      return isSignedIn()
        && newDoc().managedDeviceFirebaseUid == request.auth.uid
        && newDoc().claimed == false
        && newDoc().schemaVersion == 1;
    }

    // Atomic claim: caller flips claimed false→true. No other field may
    // change (block in-place mutation of token/expiresAt/managedDeviceId
    // by a hostile claimer).
    function isValidClaimUpdate() {
      return isSignedIn()
        && existingDoc().claimed == false
        && newDoc().claimed == true
        && newDoc().schemaVersion == existingDoc().schemaVersion
        && newDoc().managedDeviceId == existingDoc().managedDeviceId
        && newDoc().managedDeviceFirebaseUid == existingDoc().managedDeviceFirebaseUid
        && newDoc().expiresAt == existingDoc().expiresAt;
    }

    // /links/{linkId} root doc — link membership helpers.
    function isLinkAdmin(linkId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/links/$(linkId)).data.adminId == request.auth.uid;
    }

    function isLinkManaged(linkId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/links/$(linkId)).data.managedDeviceFirebaseUid == request.auth.uid;
    }

    function isLinkParty(linkId) {
      return isLinkAdmin(linkId) || isLinkManaged(linkId);
    }

    // ─── /pairings/{token} (FR-029, contracts/pairing-token.md) ────────

    match /pairings/{token} {
      // Anyone authenticated can read — the token IS the secret (anyone
      // with the QR can read; we don't gate further to keep claim flow
      // friction-free).
      allow read: if isSignedIn();

      // Managed creates with matching uid (anti-spam).
      allow create: if isValidPairingCreate();

      // Update is the atomic claim transaction performed by the admin.
      // No field-level lock on adminId — the admin pairs by writing
      // /links/{linkId} atomically (enforced via batched-write contract,
      // not here, because Firestore Rules can't see a batch).
      allow update: if isValidClaimUpdate();

      // Decline / single-use cleanup — only the Managed creator may delete.
      allow delete: if isManagedUid(existingDoc().managedDeviceFirebaseUid);
    }

    // ─── /links/{linkId} (FR-028, contracts/link.md) ───────────────────

    match /links/{linkId} {
      // Both sides of the link may read the root doc.
      allow read: if isSignedIn()
        && (existingDoc().adminId == request.auth.uid
            || existingDoc().managedDeviceFirebaseUid == request.auth.uid);

      // Create: admin transaction — paired with the /pairings/{token}
      // claim update. The admin's uid must end up as adminId; the
      // managedDeviceFirebaseUid must come from a pre-existing
      // /pairings/{token} doc (we can't cross-reference in pure rules,
      // so we trust the client-side batched transaction to carry both
      // updates atomically). The schemaVersion and identity fields are
      // sanity-checked here.
      allow create: if isSignedIn()
        && newDoc().adminId == request.auth.uid
        && newDoc().managedDeviceFirebaseUid is string
        && newDoc().managedDeviceId is string
        && newDoc().schemaVersion == 1;

      // Root doc is immutable post-create (contract §Security Rules).
      allow update: if false;

      // Delete: Managed side revokes (FR-033) OR admin removes from their list.
      // Admin-side delete added so the reconnect-dedup cleanup and the "Удалить"
      // button on the admin paired-devices screen can prune stale link docs.
      allow delete: if isManagedUid(existingDoc().managedDeviceFirebaseUid)
                     || existingDoc().adminId == request.auth.uid;

      // ─── /links/{linkId}/state/{stateId} ──────────────────────────
      // FR-027, contracts/state-bootstrap.md.
      match /state/{stateId} {
        allow read:   if isLinkParty(linkId);
        allow create: if isLinkManaged(linkId)
                       && newDoc().schemaVersion == 1;
        // Managed may update fcmToken / presetId; cannot lower schemaVersion.
        allow update: if isLinkManaged(linkId)
                       && newDoc().schemaVersion >= existingDoc().schemaVersion;
        allow delete: if isLinkManaged(linkId);
      }

      // ─── /links/{linkId}/config/{configId} ────────────────────────
      // Spec 008 (FR-010, FR-011): collaborative editing. Both admin AND
      // managed device are equal editors (FR-050 «единый editor pattern»).
      // Write authorization: any link party. Optimistic concurrency on
      // serverUpdatedAt is enforced client-side через
      // RemoteSyncBackend.runTransaction (Firestore Rules can't see the
      // client's prior read-set; transaction-based check is standard
      // Firestore pattern, see specs/008-.../research.md §1).
      //
      // Schema invariant: schemaVersion is set on create and cannot
      // decrease on update (per contract/config.md §Security Rules).
      match /config/{configId} {
        allow read:   if isLinkParty(linkId);
        allow create: if isLinkParty(linkId)
                       && newDoc().schemaVersion == 1;
        allow update: if isLinkParty(linkId)
                       && newDoc().schemaVersion >= existingDoc().schemaVersion;
        // Delete only via revoke path (Managed side, deletes whole subtree).
        allow delete: if isLinkManaged(linkId);
      }

      // ─── /links/{linkId}/configHistory/{autoId} ──────────────────
      // Spec 009 (FR-036..FR-045b): config history + rollback.
      // Both admin and Managed are link parties; both can record snapshots
      // before publishing (FR-036). History is immutable — no update.
      // Delete is allowed via client-orchestrated housekeeping
      // (FR-038, ≤10 snapshots) until SRV-CONFIG-001 migrates to
      // server-side cron. Anti-spoof: recordedFromDeviceId MUST equal
      // request.auth.uid (FR-045a) — server-enforced integrity gate.
      //
      // Path note: spec 009 contracts/config-history.md prints the path
      // as `/links/{linkId}/config/history/{autoId}` (shorthand), but
      // raw Firestore requires alternating collection/doc segments, so
      // the canonical implementation uses a sibling top-level collection
      // `configHistory`. See docs/dev/project-backlog.md for the doc-fix
      // task.
      //
      // TODO(server-roadmap SRV-CONFIG-001): migrate history writes
      // to server-side (eliminate client recordedFromDeviceId trust,
      // atomic publish+history via Cloud Function or own server).
      match /configHistory/{autoId} {
        allow read: if isLinkParty(linkId);
        allow create: if isLinkParty(linkId)
                       && request.resource.data.recordedFromDeviceId == request.auth.uid
                       && request.resource.data.snapshotSchemaVersion is int
                       && request.resource.data.snapshotSchemaVersion >= 1;
        allow update: if false;
        // Housekeeping deletes oldest entries when count exceeds 10.
        // Client-orchestrated until SRV-CONFIG-001.
        allow delete: if isLinkParty(linkId);
      }

      // ─── /links/{linkId}/capabilities/{capId} ─────────────────────
      // Managed writes provider snapshot; admin reads.
      match /capabilities/{capId} {
        allow read:  if isLinkParty(linkId);
        allow write: if isLinkManaged(linkId);
      }

      // ─── /links/{linkId}/health/{healthId} ────────────────────────
      // Managed writes battery/connectivity; admin reads.
      match /health/{healthId} {
        allow read:  if isLinkParty(linkId);
        allow write: if isLinkManaged(linkId);
      }

      // ─── /links/{linkId}/commands/{cmdId} ─────────────────────────
      // Admin issues commands (spec 009); Managed updates with ack/result.
      match /commands/{cmdId} {
        allow read:   if isLinkParty(linkId);
        allow create: if isLinkAdmin(linkId);
        allow update: if isLinkManaged(linkId);
        allow delete: if isLinkAdmin(linkId);
      }

      // ─── /links/{linkId}/devices/{deviceId} (spec 011 FR-006..009) ─
      // DeviceIdentity Pub publication: каждое устройство публикует свой
      // X25519 + Ed25519 public key + Ed25519 signature над payload.
      // Подробности — specs/011-.../contracts/device-identity.md.
      match /devices/{deviceId} {
        function freshSignedTimestamp() {
          // signedTimestamp в пределах 7 дней (replay-attack mitigation)
          // с 1-минутным skew для clock drift.
          let nowMillis = request.time.toMillis();
          let signedMillis = request.resource.data.signedTimestamp;
          return (nowMillis - signedMillis) < (7 * 24 * 60 * 60 * 1000)
              && (nowMillis - signedMillis) > -(60 * 1000);
        }

        function hasRequiredFields() {
          let d = request.resource.data;
          return d.schemaVersion == 1
              && d.deviceId is string
              && d.publicKey is string
              && d.signingPublicKey is string
              && d.signedTimestamp is int
              && d.signature is string
              && d.algorithm == "x25519+ed25519";
        }

        function isOwnDevice() {
          return exists(/databases/$(database)/documents/links/$(linkId)/deviceOwnership/$(deviceId))
              && get(/databases/$(database)/documents/links/$(linkId)/deviceOwnership/$(deviceId)).data.ownerUid == request.auth.uid;
        }

        // Любой member пары может read peer's Pub'ы.
        allow read:   if isLinkParty(linkId);
        // Create: link party, deviceId совпадает с path, все поля валидны, signedTimestamp свежий.
        allow create: if isLinkParty(linkId)
                       && request.resource.data.deviceId == deviceId
                       && hasRequiredFields()
                       && freshSignedTimestamp();
        // Update: только own device (через deviceOwnership claim), валидация полная.
        allow update: if isLinkParty(linkId)
                       && isOwnDevice()
                       && hasRequiredFields()
                       && freshSignedTimestamp();
        // Delete: только own device.
        allow delete: if isOwnDevice();
      }

      // ─── /links/{linkId}/deviceOwnership/{deviceId} (spec 011) ─────
      // Auxiliary collection: race-free deviceId claim. Только первый writer
      // (с тем же uid) может create — далее immutable.
      match /deviceOwnership/{deviceId} {
        allow read: if isLinkParty(linkId);
        allow create: if isSignedIn()
                       && request.resource.data.ownerUid == request.auth.uid
                       && !exists(/databases/$(database)/documents/links/$(linkId)/deviceOwnership/$(deviceId));
        allow update, delete: if false;
      }
    }

    // ─── /devices/{managedDeviceId} (per data-model.md §DocPath) ───────
    // Spec 007 does not write to this collection (deferred to spec 008
    // capability/health export). Leave deny-all so any accidental write
    // is rejected — when spec 008 needs it, expand here.
    match /devices/{managedDeviceId} {
      allow read, write: if false;
    }

    // ─── Spec 017 (F-4 AuthProvider) — identity-links + users ──────────
    //
    // identity-links/google/{providerAccountId} — реверс-mapping
    // Google `sub` claim → наш stableId UUID. Атомарный create через
    // Firestore transaction (race-safe — два устройства с одним Google
    // аккаунтом получат одинаковый stableId).
    //
    // Per spec 017 FR-016a, contract identity-link-v1.md.
    //
    // NB: rule использует `request.auth.uid == providerAccountId` — это
    // означает, что Firebase Auth UID должен совпадать с Google `sub`
    // claim. Firebase **не** делает это автоматически (UID назначается
    // Firebase). Альтернатива — использовать custom claims или server-
    // verified token. Для MVP мы доверяем клиенту: SDK SignInWithCredential
    // exchange гарантирует что Firebase UID = google.com providerData.uid.
    // Production-уровень — Cloud Function для server-side verification
    // (server-roadmap SRV-AUTH-IDENTITY-001).
    //
    // TODO(server-roadmap SRV-AUTH-IDENTITY-002): добавить custom claim
    // `googleSub` в Firebase Auth user, проверять `request.auth.token.googleSub`
    // вместо `request.auth.uid` — устраняет необходимость доверять клиенту.
    match /identity-links/google/{providerAccountId} {
      allow read: if request.auth != null
                    && request.auth.uid == providerAccountId;
      allow create: if request.auth != null
                    && request.auth.uid == providerAccountId
                    && !exists(/databases/$(database)/documents/identity-links/google/$(providerAccountId))
                    && request.resource.data.keys().hasOnly(['schemaVersion', 'stableId', 'createdAt'])
                    && request.resource.data.schemaVersion == 1
                    && request.resource.data.stableId is string
                    && request.resource.data.stableId.size() == 36
                    && request.resource.data.stableId.matches('^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$')
                    && request.resource.data.createdAt == request.time;
      // Immutable: identity-link создаётся один раз, не редактируется.
      allow update, delete: if false;
    }

    // users/{stableId} — каноническая запись профиля. Spec 017 создаёт
    // doc вместе с identity-link при first-time sign-in. Update / delete
    // запрещены F-4; их откроют F-5 (профиль) и S-6 (right to be forgotten).
    match /users/{stableId} {
      allow read: if request.auth != null
                  && exists(/databases/$(database)/documents/identity-links/google/$(request.auth.uid))
                  && get(/databases/$(database)/documents/identity-links/google/$(request.auth.uid)).data.stableId == stableId;
      allow create: if request.auth != null
                    && existsAfter(/databases/$(database)/documents/identity-links/google/$(request.auth.uid))
                    && getAfter(/databases/$(database)/documents/identity-links/google/$(request.auth.uid)).data.stableId == stableId
                    && request.resource.data.keys().hasOnly(['schemaVersion', 'stableId', 'createdAt'])
                    && request.resource.data.schemaVersion == 1
                    && request.resource.data.stableId == stableId
                    && request.resource.data.createdAt == request.time;
      // Immutable until F-5 ConfigCipher / S-6 deletion specs override.
      allow update, delete: if false;
    }

    // ─── default deny for everything else ──────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
