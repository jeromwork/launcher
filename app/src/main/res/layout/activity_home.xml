<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/profile_line"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:gravity="center_vertical"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:contentDescription="@string/home_profile_line_a11y" />

    <TextView
        android:id="@+id/catalog_line"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:minHeight="48dp"
        android:gravity="center_vertical"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:contentDescription="@string/home_catalog_line_a11y" />

    <include
        android:id="@+id/include_contact_tile"
        layout="@layout/view_contact_tile" />

    <include
        android:id="@+id/include_confirmation"
        layout="@layout/view_whatsapp_confirmation" />

    <include
        android:id="@+id/include_warning"
        layout="@layout/view_whatsapp_warning" />
</LinearLayout>
