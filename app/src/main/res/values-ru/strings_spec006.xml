<?xml version="1.0" encoding="utf-8"?>
<!--
  Spec 006 user-facing strings (ru-RU). Default (en) lives in values/strings_spec006.xml.

  «Авиарежим» — короткое слово, доступно для пожилого пользователя. Альтернатива
  «Самолётный режим» рассматривается для спека 010 Setup Assistant копирайтер
  (более длинно, но яснее).

  «Включить звук» поднимает громкость до 50% (FR-027) — explicit «звук включён»
  notice не нужен, исчезновение баннера сообщает результат.
-->
<resources>
    <!-- Авиарежим -->
    <string name="banner_airplane_text">Авиарежим включён</string>
    <string name="banner_airplane_action">Выключить авиарежим</string>
    <string name="banner_airplane_icon_desc">Иконка самолётного режима</string>

    <!-- Звук выключен -->
    <string name="banner_mute_text">Звук выключен</string>
    <string name="banner_mute_action">Включить звук</string>
    <string name="banner_mute_icon_desc">Иконка отключённого звука</string>

    <!-- Toast при отказе действия (FR-050) -->
    <string name="toast_action_failed_audio">Не удалось — проверьте настройки звука</string>
    <string name="toast_feature_unavailable">Функция недоступна на этом устройстве</string>
</resources>
