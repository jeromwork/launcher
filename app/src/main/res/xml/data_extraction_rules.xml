<?xml version="1.0" encoding="utf-8"?>
<!--
  Android Auto Backup rules для Android 12+ (`android:dataExtractionRules`).
  Same intent as backup_rules.xml но новый XML schema разделяет cloud-backup
  и device-transfer rules.

  Per spec 006 FR-057:
  - Cloud backup и device transfer оба EXCLUDE capability/health snapshots
    (per-device transient state).
  - Settings snapshot включён по умолчанию (пользовательские toggles
    переносятся на новый телефон).
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore/com.launcher.capability.snapshot_v1.preferences_pb" />
        <exclude domain="file" path="datastore/com.launcher.health.snapshot_v1.preferences_pb" />
        <!--
          Spec 009 FR-046a: reserve namespace for any future local
          contacts cache. In spec 009 contacts live inside
          /config/current; if a future spec adds a SQLite/Room cache of
          PII третьих лиц it MUST use this excluded path
          (GDPR transfer-to-processor mitigation).
        -->
        <exclude domain="database" path="contacts_cache.db" />
        <!--
          Spec 016 (F-CRYPTO) — wrapped private keys MUST NOT travel to
          Google Drive backup. Even though they are wrapped by a TEE key
          that itself cannot be backed up (Android Keystore aliases are
          device-local), shipping the wrappedKey bytes to the cloud is
          unnecessary risk surface. Restoring on a new device must go
          through ADR-008 social recovery, not backup restore.
        -->
        <exclude domain="file" path="keys/" />
        <!--
          Spec 017 (F-4 AuthProvider) — EncryptedLocalSessionStore хранит
          Firebase JWT + Google refresh token в auth_session_v1.preferences.xml.
          Бэкап refresh token'а в Google Drive — недопустимо: после restore
          на новом устройстве токен потерял privileges (Google инвалидирует),
          а копия облака может быть использована атакующим до инвалидации.
          После restore — sign-in заново (FR-020, research.md §R10).
        -->
        <exclude domain="sharedpref" path="auth_session_v1.preferences.xml" />
        <exclude domain="sharedpref" path="auth_session_v1.preferences.xml.bak" />
        <!--
          Spec 018 (F-5) — H-1 / H-2 mitigations MUST NOT travel cloud-backup:
          • passphrase_attempts_v1 — persistent attempt counter (3-strike lockout
            для recovery passphrase). Restore из cloud → счётчик сброшен →
            attacker bypass'ит lockout. Accepted residual: Clear App Data
            тоже сбрасывает счётчик локально, но также удаляет root key cache,
            поэтому attacker всё равно начинает с zero progress. Cloud-backup
            restore — другой attack: attacker может восстановить state до lockout
            не имея физ. доступа к устройству.
          • tolu_schema_versions_v1 — Trust-On-Last-Use schemaVersion memory.
            Restore старого state'а позволяет roll-back атаку: attacker
            подсовывает старую SealedConfig версию которая прошла бы validation.
        -->
        <exclude domain="file" path="datastore/passphrase_attempts_v1.preferences_pb" />
        <exclude domain="file" path="datastore/tolu_schema_versions_v1.preferences_pb" />
        <!--
          Spec 018 (F-5b) — device_identity_v1 хранит DeviceId + Pub_X25519
          текущего устройства. Backup → restore на новое устройство приведёт
          к двойной публикации одного DeviceId в Public Key Directory с
          разными priv keys (старый priv остался в TEE старого устройства).
          Recipients не смогут open envelope'ы (priv mismatch), reinstall
          flow ломается. Лучше fresh keypair при reinstall.
        -->
        <exclude domain="file" path="datastore/device_identity_v1.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/com.launcher.capability.snapshot_v1.preferences_pb" />
        <exclude domain="file" path="datastore/com.launcher.health.snapshot_v1.preferences_pb" />
        <exclude domain="database" path="contacts_cache.db" />
        <!-- Spec 016 (F-CRYPTO) — see cloud-backup comment above. -->
        <exclude domain="file" path="keys/" />
        <!-- Spec 017 (F-4) — same rationale as cloud-backup. -->
        <exclude domain="sharedpref" path="auth_session_v1.preferences.xml" />
        <exclude domain="sharedpref" path="auth_session_v1.preferences.xml.bak" />
        <!-- Spec 018 (F-5) — see cloud-backup comment above. -->
        <exclude domain="file" path="datastore/passphrase_attempts_v1.preferences_pb" />
        <exclude domain="file" path="datastore/tolu_schema_versions_v1.preferences_pb" />
        <!-- Spec 018 (F-5b) — device_identity_v1 (DeviceId + Pub_X25519) MUST NOT
             travel device-to-device transfer either — fresh keypair после migration. -->
        <exclude domain="file" path="datastore/device_identity_v1.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
