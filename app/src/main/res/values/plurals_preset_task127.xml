<?xml version="1.0" encoding="utf-8"?>
<!--
  TASK-127 T127-030 (FR-008, US-3) — wizard progress plural.

  Resolved via AndroidStringResolver.resolvePlural (getIdentifier over
  res/plurals), with {current}/{total} interpolated by the resolver — hence the
  brace placeholders rather than %d.

  Russian forms live in values-ru/ (one / few / many / other).
-->
<resources>

    <plurals name="wizard_step_of">
        <item quantity="one">Step {current} of {total}</item>
        <item quantity="other">Step {current} of {total}</item>
    </plurals>

</resources>
