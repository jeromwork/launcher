        <item name="launcherSlotMinSize">@dimen/slot_min_size</item>
        <item name="launcherSlotLabelTextSize">@dimen/slot_label_text_size</item>
    </style>

    <style name="Theme.Launcher.Workspace" parent="Theme.Launcher">
        <item name="launcherFlowTabHeight">@dimen/flow_tab_height</item>
        <item name="launcherSlotMinSize">@dimen/slot_min_size</item>
        <item name="launcherSlotLabelTextSize">@dimen/slot_label_text_size</item>
    </style>

    <style name="Theme.Launcher.LauncherPreset" parent="Theme.Launcher">
        <item name="launcherFlowTabHeight">@dimen/flow_tab_height_launcher</item>
        <item name="launcherSlotMinSize">@dimen/slot_min_size_launcher</item>
        <item name="launcherSlotLabelTextSize">@dimen/slot_label_text_size_launcher</item>
    </style>

    <style name="Theme.Launcher.SimpleLauncher" parent="Theme.Launcher">
        <item name="launcherFlowTabHeight">@dimen/flow_tab_height_simple</item>
        <item name="launcherSlotMinSize">@dimen/slot_min_size_simple</item>
        <item name="launcherSlotLabelTextSize">@dimen/slot_label_text_size_simple</item>
    </style>
