<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      Permissions (per spec 006 FR-053/054 + spec 005 §permissions register).
      ACCESS_NETWORK_STATE — нужен AndroidHealthCollector для ConnectivityManager.NetworkCallback
      (Wifi/Mobile/None detection per FR-018). Normal permission, auto-granted, нет runtime prompt.
      No QUERY_ALL_PACKAGES (Play policy + spec 006 NFR-008 zero new dangerous permissions).
    -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!--
      TASK-126 Phase 4 (FR-012, US-4, CL-9): boot-check receiver dispatches
      a WorkManager job to re-apply `critical=true` preset components after
      a device reboot. BootCheckReceiver.onReceive() returns within ~100 ms;
      actual reconcile runs in BootCheckWorker outside the receiver context.
    -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!--
      Spec 009 FR-023: READ_CONTACTS for admin-only ACTION_PICK flow
      (system contact picker in EditorScreen). Permission is requested
      lazily at first picker tap, with rationale (FR-023a) + manual-entry
      alternative (FR-023a) + deep-link to system settings on deny
      (FR-023b). Managed-устройство НЕ запрашивает этот permission.
      TODO(flavour-split): isolate this в admin-only build variant once
      Managed/admin flavours land.
    -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!--
      Spec 010 FR-012 / FR-013 (T001 + Phase 0 critical):
      ACTION_CALL one-tap path. Runtime-prompted on first call-tile tap; rationale
      shown в spec 010 CallPhoneRationaleScreen («Чтобы звонок шёл сразу одной
      кнопкой»). On deny → PhoneHandler falls back to ACTION_DIAL.
    -->
    <uses-permission android:name="android.permission.CALL_PHONE" />

    <!--
      Spec 010 FR-008 / T044 — POST_NOTIFICATIONS runtime permission (Android
      13+). Requested via wizard step «Чтобы внук видел, что у тебя всё в
      порядке». On <33 platforms the permission isn't honoured — declaration
      is harmless. Recommended-criticality в SetupCheck engine (denial does
      not break core launcher; surfaces as `?M` badge in Settings).
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      Spec 010 T002 (Phase 0 critical): declare telephony as optional so
      tablets / Wear / Chromebooks without dialer hardware still install. App
      handles absence gracefully (PhoneHandler returns failure result).
    -->
    <uses-feature android:name="android.hardware.telephony" android:required="false" />

    <!--
      Package visibility (Android 11+, per spec 005 plan §Risks row 2 + permissions-platform CHK-008):
      - <intent> with MAIN/LAUNCHER lets AppIndex enumerate every launchable app (Workspace catalog).
      - explicit <package> entries let provider availability check resolve known target packages
        (whatsapp, telegram, youtube primary + alternate distributions).
      - <intent> entries for tel:, smsto:, https: let provider availability resolve dial / sms /
        browser handlers without scanning every package.
      Contract: NO QUERY_ALL_PACKAGES requested per Play policy (security CHK-015).
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>

        <!-- WhatsApp providers -->
        <package android:name="com.whatsapp" />
        <package android:name="com.whatsapp.w4b" />

        <!-- Telegram providers -->
        <package android:name="org.telegram.messenger" />
        <package android:name="org.telegram.plus" />

        <!-- YouTube providers -->
        <package android:name="com.google.android.youtube" />
        <package android:name="com.google.android.youtube.tv" />

        <!--
          Spec 010 T003 (Phase 0 CRITICAL — CHK-permissions-008/020):
          Both DIAL and CALL intents are needed for tel: scheme resolution on
          Android 11+. Without CALL declaration, packageManager.queryIntentActivities
          returns empty for ACTION_CALL even with CALL_PHONE permission granted —
          breaks FR-012 / FR-014 (two-tap call from confirmation dialog).
        -->
        <intent>
            <action android:name="android.intent.action.DIAL" />
            <data android:scheme="tel" />
        </intent>
        <intent>
            <action android:name="android.intent.action.CALL" />
            <data android:scheme="tel" />
        </intent>

        <!-- SMS handlers -->
        <intent>
            <action android:name="android.intent.action.SENDTO" />
            <data android:scheme="smsto" />
        </intent>

        <!-- Browser handlers -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="http" />
        </intent>

        <!--
          Spec 009 FR-035a: market://details?id=<pkg> resolution for
          OpenAppDispatcher Play Store fallback chain.
        -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="market" />
        </intent>
    </queries>

    <application
        android:name=".LauncherApplication"
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Launcher.Workspace">

        <activity
            android:name=".firstlaunch.FirstLaunchActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".HomeActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!--
          Spec 006 debug screens (US-1 / US-3 Independent Tests).
          exported=true с пустым intent-filter: НЕ появляется в системном
          launcher (нет MAIN/LAUNCHER), но launchable через `adb shell am start -n`
          для ручной диагностики snapshot rebuild на эмуляторе. Безопасно:
          показывают только non-PII device telemetry per FR-056. До public release —
          рассмотреть isolation через debug build variant.
        -->
        <activity
            android:name=".debug.CapabilitySnapshotDebugActivity"
            android:exported="true"
            android:label="Capability Debug" />
        <activity
            android:name=".debug.HealthSnapshotDebugActivity"
            android:exported="true"
            android:label="Health Debug" />
        <!--
          Spec 011 FR-070 / US-6 — debug smoke screen для self-roundtrip
          + cross-device validation (Phase A/B/C из smoke/README.md).
          Запуск: adb shell am start -n com.launcher.app/.debug.Spec011SmokeDebugActivity
          Получает все crypto-port'ы через Koin DI (cryptoModule, T061 wiring).
        -->
        <activity
            android:name=".debug.Spec011SmokeDebugActivity"
            android:exported="true"
            android:label="Spec 011 Smoke" />

        <!--
          Spec 014 F-014.0 visual smoke — renders all 7 composables on
          one scrollable surface. No backend / DI dependencies (composables
          are stateless / app-only). T200 verification:
          adb shell am start -n com.launcher.app.mock/com.launcher.app.debug.Spec014SmokeDebugActivity
          (.mock suffix for mockBackend variant).
        -->
        <activity
            android:name=".debug.Spec014SmokeDebugActivity"
            android:exported="true"
            android:label="Spec 014 Smoke" />

        <!--
          TASK-69 (FR-017 / FR-020 / FR-021) — the single Settings host: a
          Profile projection (Wizard is the other), plus the PendingChecklist +
          WalkThrough button + LocaleDivergence indicator kept from TASK-7.
          Launched from HomeActivity's "Settings" tap. exported=false: only
          launched from inside the app.
        -->
        <activity
            android:name=".settings.SettingsActivity"
            android:exported="false"
            android:label="Settings" />

        <!--
          Spec 007 pairing host (Managed-side flow). Launched from Settings
          via explicit intent. Stays adb-launchable for QA via
          `am start -n com.launcher.app/.ui.pairing.PairingActivity` —
          same convention as the spec 006 debug activities above.
        -->
        <activity
            android:name=".ui.pairing.PairingActivity"
            android:exported="true"
            android:label="@string/pairing_toggle_title">
            <!--
              Pairing deep-link entry (FR-005 fallback / admin-side claim before
              QrScannerScreen lands in spec 008). Lets `launcher://pair?token=XXX`
              from a sister-device QR resolve directly into PairingActivity, which
              routes the inbound token through PairingViewModel.claimAsAdmin().
            -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="launcher" android:host="pair" />
            </intent-filter>
        </activity>

        <!--
          Spec 009 FR-027 / FR-027a: VCard share intent receiver.
          launchMode="singleTask" + handleNewIntent ensures a second share
          while the activity is already open delivers via onNewIntent
          rather than spawning a duplicate task entry.

          Accepts ACTION_SEND with MIME text/x-vcard. The launcher does not
          export ACTION_VIEW для vCard URIs (we don't want to be a default
          handler — only catch explicit shares).
        -->
        <activity
            android:name=".contacts.VCardReceiveActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:label="@string/vcard_receive_title"
            android:taskAffinity=""
            android:excludeFromRecents="true">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/x-vcard" />
                <data android:mimeType="text/vcard" />
            </intent-filter>
        </activity>

        <!--
          Spec 010 T046 — GMS hard-block screen (FR-042). Launched explicitly
          by FirstLaunchActivity when GoogleApiAvailability reports MissingFatal.
          NEVER reachable from outside the app: android:exported="false" enforced
          by Spec010IsolationTest.T010 (plan §11 C-9, CHK-security-009).
        -->
        <activity
            android:name=".setup.GmsHardBlockActivity"
            android:exported="false"
            android:label="@string/setup_gms_hard_block_title" />

        <!-- TASK-126 T054/T055 — preset-composition wizard host.
             Splash theme keeps until WizardViewModel emits its first
             non-Loading state. Replaces the legacy `.wizard.WizardActivity`
             + `.wizard.PlayStoreFallbackActivity` pair that lived here
             pre-TASK-126. -->
        <activity
            android:name=".wizard.WizardHostActivity"
            android:exported="false"
            android:theme="@style/Theme.Launcher.WizardSplash"
            android:label="@string/wizard_loading" />

        <!--
          TASK-126 Phase 4 T080 — dispatch-only receiver for BOOT_COMPLETED.
          Enqueues BootCheckWorker via WorkManager and returns immediately.
          Not exported: only the system fires BOOT_COMPLETED for the app's
          own receiver.
        -->
        <receiver
            android:name=".boot.BootCheckReceiver"
            android:exported="true"
            android:enabled="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!--
          Spec 008 FR-022 T3: disable default WorkManager auto-init so our
          custom Configuration.Provider (LauncherApplication) is used. This
          gives ConfigRefreshWorker its Koin-injected dependencies
          (LinkRegistry + ConfigApplier) via ConfigSyncWorkerFactory.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>
</manifest>
