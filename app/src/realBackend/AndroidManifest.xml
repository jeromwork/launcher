<?xml version="1.0" encoding="utf-8"?>
<!--
  realBackend-flavor manifest overlay (spec 007 T056).

  Adds the FCM service entry that wakes the launcher on incoming
  data-message push. mockBackend doesn't register it because there is no
  Firebase Messaging SDK in that flavor.

  Permission rationale:
   - INTERNET: required for Firestore, Firebase Auth, and the Cloudflare
     Worker call.
   - POST_NOTIFICATIONS (Android 13+): not used for spec 007 silent-data
     pushes (contracts/fcm-payload.md), but the FCM SDK still asks the
     system for it on first launch; we keep it absent so the user never
     sees a notification prompt for spec 007. If we ever surface a
     user-visible notification we'll add it then.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- CAMERA — admin-side QR scanner (spec 007 FR-005, T089). Runtime
         permission, requested by QrScannerActivity on entry. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application>

        <!--
          QR scanner host (admin-side pairing claim entry). CameraX preview +
          ML Kit barcode detection. On first successful scan emits a deep-link
          launcher://pair?token=XXX which routes back to PairingActivity
          via its existing intent-filter.
        -->
        <activity
            android:name="com.launcher.app.ui.pairing.QrScannerActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:label="@string/pairing_scan_title" />


        <!--
          FCM data-message entry point per FR-016. Routes to
          com.launcher.adapters.push.LauncherFirebaseMessagingService which
          parses payloads through FcmReceiverContract and dispatches to the
          injected PushReceiver.
        -->
        <service
            android:name="com.launcher.adapters.push.LauncherFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>
</manifest>
