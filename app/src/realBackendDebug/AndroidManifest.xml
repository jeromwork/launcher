<?xml version="1.0" encoding="utf-8"?>
<!--
  realBackend + debug variant overlay.

  History:
   - До 2026-06-22: здесь жил `android:networkSecurityConfig` + XML, который
     разрешал cleartext к 127.0.0.1/10.0.2.2/localhost для тестов
     CloudConfigEncryptionE2ETest на Firebase Emulator.
   - 2026-06-22: overlay снят, потому что Ktor (HttpPushTrigger в спеке 019)
     + Android Network Security Config с domain-config выбрасывают
     "hostname aware checkServerTrusted" на любой HTTPS-вызов вне whitelist.
     Это блокировало F-5c push-trigger E2E test.

  TODO(emulator-tests-cleartext): когда понадобится снова гонять
  CloudConfigEncryptionE2ETest или другие emulator-based тесты — добавить
  XML overlay ТОЛЬКО в `androidTest` source set (res/xml внутри
  src/androidTest/), чтобы он не влиял на debug-сборку основного APK.
  См. project-backlog.md если/когда задача всплывёт.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application tools:targetApi="24">
        <!-- Spec 018 (F-5b) round-trip приёмка через ADB broadcast. Receiver
             только в realBackendDebug — не попадает в release.
             android:exported="true" — receiver вызывается из adb (uid=shell),
             что system требует exported. Безопасно: только в debug build. -->
        <receiver
            android:name="com.launcher.app.debug.Spec018ConfigRoundtripReceiver"
            android:exported="true"
            tools:ignore="ExportedReceiver">
            <intent-filter>
                <action android:name="com.launcher.app.DEBUG_F5B_ROUNDTRIP" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
