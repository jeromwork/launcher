# Gradle
.gradle/
build/
out/
local.properties

# Local portable toolchains (downloaded by setup scripts — JDK, kotlinc, etc.)
.tools/

# Android
*.apk
*.aab
*.ap_
*.dex
captures/

# IDE
.idea/
*.iml
.DS_Store
Thumbs.db

# Kotlin / JVM (wrapper JAR is versioned — do not ignore)
*.class
*.jar
!gradle/wrapper/gradle-wrapper.jar
*.log
*.tmp
*.swp

# Kotlin compiler daemon cache (regenerated on every build).
.kotlin/

# Env
.env
.env.*

# Claude Code harness — runtime locks/state, not project content
.claude/scheduled_tasks.lock

# Cloudflare Wrangler local runtime cache (regenerated on every wrangler dev/run)
.wrangler/

# Node — Worker dependencies (regenerated by `npm install`; never commit)
node_modules/
.package-lock.json

# Firebase per-developer keys (committed template — app/google-services.json.template).
# Real google-services.json содержит project-specific API key и SHA-1 fingerprints
# — каждый разработчик должен подложить свой (см. docs/dev/auth-setup.md).
app/google-services.json
google-services.json

# Local diagnostic artifacts — screenshots, ad-hoc test scripts. Не часть
# source-of-truth; полезны во время сессии и удаляются между сессиями.
tmp/
firestore-tests/test-*.mjs

