{
  "workspace": {
    "namePrefix": "AUTO_",
    "selectors": {
      "newWorkspaceButton": [
        "button:has-text('New Flow')",
        "button:has-text('New Project')",
        "button:has-text('Create')"
      ],
      "workspaceNameInput": [
        "input[placeholder*='Flow']",
        "input[placeholder*='Name']"
      ],
      "workspaceCreateSubmit": [
        "button:has-text('Create')",
        "button:has-text('Save')"
      ]
    }
  },
  "session": {
    "loggedInSelectors": [
      "text=Flows",
      "text=Projects",
      "text=New Flow"
    ],
    "loginRequiredSelectors": [
      "input[type='password']",
      "button:has-text('Sign in')",
      "button:has-text('Log in')"
    ]
  },
  "canvas": {
    "selector": ".react-flow",
    "addNodeButton": [
      "button:has-text('Add Component')",
      "button:has-text('Add Node')",
      "button:has-text('Add')"
    ],
    "nodeSearchInput": [
      "input[placeholder*='Search']",
      "input[placeholder*='component']"
    ],
    "nodeResultPattern": "text={{node}}",
    "canvasNodeByTitlePattern": "xpath=//*[contains(@class,'react-flow__node')]//*[normalize-space(text())='{{node}}']/ancestor::*[contains(@class,'react-flow__node')][1]",
    "sourcePortPattern": "[data-node-name='{{fromNode}}'] [data-handleid='{{fromPort}}']",
    "targetPortPattern": "[data-node-name='{{toNode}}'] [data-handleid='{{toPort}}']"
  },
  "run": {
    "runButton": [
      "button:has-text('Run')",
      "button:has-text('Play')"
    ],
    "saveButton": [
      "button:has-text('Save')"
    ],
    "exportButton": [
      "button:has-text('Export')"
    ],
    "runSuccessSelectors": [
      "text=Success",
      "text=Completed"
    ]
  },
  "nodes": [
    {
      "name": "Chat Input",
      "position": { "x": 220, "y": 200 }
    },
    {
      "name": "OpenAI",
      "position": { "x": 560, "y": 200 }
    },
    {
      "name": "Chat Output",
      "position": { "x": 900, "y": 200 }
    }
  ],
  "edges": [
    { "fromNode": "Chat Input", "fromPort": "text", "toNode": "OpenAI", "toPort": "input" },
    { "fromNode": "OpenAI", "fromPort": "output", "toNode": "Chat Output", "toPort": "text" }
  ]
}
