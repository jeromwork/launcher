{
  "name": "langflow-mcp-automation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Langflow browser automation with Playwright + MCP-friendly runtime",
  "scripts": {
    "pipeline": "node ./langflow-pipeline.mjs",
    "pipeline:watch": "set WATCH_MODE=on&& node ./langflow-pipeline.mjs",
    "pipeline:headless": "set WATCH_MODE=off&& node ./langflow-pipeline.mjs"
  },
  "dependencies": {
    "playwright": "^1.54.2"
  }
}
